rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.admin == true;
    }

    function isOwnUser(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isSignedInUser(userId) {
      return signedIn() && userId is string && userId == request.auth.uid;
    }

    function storeDoc(storeId) {
      return get(/databases/$(database)/documents/stores/$(storeId));
    }

    function storeData(storeId) {
      return storeDoc(storeId).data;
    }

    function storeMemberIds(storeId) {
      return storeExists(storeId) && storeData(storeId).memberUserIds is list
        ? storeData(storeId).memberUserIds
        : [];
    }

    function storeAdminIds(storeId) {
      return storeExists(storeId) && storeData(storeId).adminUserIds is list
        ? storeData(storeId).adminUserIds
        : [];
    }

    function storeExists(storeId) {
      return storeId is string &&
        storeId.size() > 0 &&
        exists(/databases/$(database)/documents/stores/$(storeId));
    }

    function canPostAsStore(storeId) {
      return signedIn() &&
        storeExists(storeId) &&
        (
          storeData(storeId).ownerId == request.auth.uid ||
          request.auth.uid in storeMemberIds(storeId) ||
          request.auth.uid in storeAdminIds(storeId)
        );
    }

    function canManageStore(storeId) {
      return signedIn() &&
        storeExists(storeId) &&
        (
          storeData(storeId).ownerId == request.auth.uid ||
          request.auth.uid in storeAdminIds(storeId)
        );
    }

    function isChatParticipantData(chatData) {
      return signedIn() &&
        (
          (
            chatData.participants is list &&
            request.auth.uid in chatData.participants
          ) ||
          chatData.buyerId == request.auth.uid ||
          chatData.sellerId == request.auth.uid
        );
    }

    function isChatParticipant() {
      return isChatParticipantData(resource.data);
    }

    function isNewChatParticipant() {
      return isChatParticipantData(request.resource.data);
    }

    function isChatParticipantById(chatId) {
      return isChatParticipantData(
        get(/databases/$(database)/documents/chats/$(chatId)).data
      );
    }

    function isSupportChatOwner() {
      return signedIn() &&
        resource.data.userId is string &&
        resource.data.userId == request.auth.uid;
    }

    function isNewSupportChatOwner() {
      return signedIn() &&
        request.resource.data.userId is string &&
        request.resource.data.userId == request.auth.uid;
    }

    function isOwnSupportChatId(chatId) {
      return signedIn() && chatId == 'support_' + request.auth.uid;
    }

    function isSupportMessageOwner(chatId) {
      return signedIn() &&
        get(/databases/$(database)/documents/support_chats/$(chatId)).data.userId == request.auth.uid;
    }

    function isSupportMessageOwnerAfter(chatId) {
      return signedIn() &&
        getAfter(/databases/$(database)/documents/support_chats/$(chatId)).data.userId == request.auth.uid;
    }

    function isSupportChatOwnerUpdate() {
      return isSupportChatOwner() &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'lastMessage',
          'lastMessageSenderRole',
          'lastMessageTime',
          'id',
          'status',
          'subject',
          'updatedAt',
          'userEmail',
          'userName',
        ]);
    }

    function isSupportUserMessage(chatId) {
      return (isSupportMessageOwner(chatId) || isSupportMessageOwnerAfter(chatId)) &&
        request.resource.data.senderId == request.auth.uid &&
        request.resource.data.senderRole == 'user' &&
        request.resource.data.text is string &&
        request.resource.data.text.size() > 0;
    }

    function isSupportAutoMessage(chatId) {
      return (isSupportMessageOwner(chatId) || isSupportMessageOwnerAfter(chatId)) &&
        request.resource.data.senderId == 'marketview_support_bot' &&
        request.resource.data.senderName == 'Suporte MarketView' &&
        request.resource.data.senderRole == 'system' &&
        request.resource.data.text ==
          'Ola! Ja va descrevendo o problema com o maximo de detalhes. Nosso suporte funciona das 8h as 18h, 7 dias por semana.';
    }

    function isOpenSupportChatForMessage(chatId) {
      return getAfter(/databases/$(database)/documents/support_chats/$(chatId)).data.status != 'closed';
    }

    function canCreateAd() {
      return signedIn() &&
        (
          request.resource.data.sellerId == request.auth.uid ||
          canPostAsStore(request.resource.data.storeId)
        );
    }

    function canWriteExistingAd() {
      return signedIn() &&
        (
          resource.data.sellerId == request.auth.uid ||
          canPostAsStore(resource.data.storeId)
        );
    }

    function isAdClickIncrement() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'clickCount',
        ]) &&
        request.resource.data.clickCount is int &&
        request.resource.data.clickCount == resource.data.clickCount + 1;
    }

    function canCreateCommunityPost(postId) {
      return signedIn() &&
        request.resource.data.id == postId &&
        request.resource.data.authorType is string &&
        request.resource.data.authorId is string &&
        request.resource.data.content is string &&
        request.resource.data.content.size() > 0 &&
        (
          (
            request.resource.data.authorType == 'user' &&
            request.resource.data.authorId == request.auth.uid
          ) ||
          (
            request.resource.data.authorType == 'store' &&
            canPostAsStore(request.resource.data.storeId)
          )
        );
    }

    function isCommunityAuthor(resourceData) {
      return (
        resourceData.authorType == 'user' &&
        isSignedInUser(resourceData.authorId)
      ) || (
        resourceData.authorType == 'store' &&
        canPostAsStore(resourceData.storeId)
      );
    }

    function unchangedCommunityPostFields() {
      return request.resource.data.id == resource.data.id &&
        request.resource.data.authorId == resource.data.authorId &&
        request.resource.data.authorType == resource.data.authorType &&
        request.resource.data.authorName == resource.data.authorName &&
        request.resource.data.authorAvatar == resource.data.authorAvatar &&
        request.resource.data.authorSubtitle == resource.data.authorSubtitle &&
        request.resource.data.content == resource.data.content &&
        request.resource.data.type == resource.data.type &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.imageUrl == resource.data.imageUrl &&
        request.resource.data.imageLabel == resource.data.imageLabel &&
        request.resource.data.storeId == resource.data.storeId &&
        request.resource.data.authorVerified == resource.data.authorVerified &&
        request.resource.data.authorOfficial == resource.data.authorOfficial;
    }

    function isLikeToggleUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'likeUserIds',
          'likeCount',
        ]) &&
        unchangedCommunityPostFields() &&
        request.resource.data.commentCount == resource.data.commentCount &&
        request.resource.data.likeUserIds is list &&
        request.resource.data.likeCount is int &&
        request.resource.data.likeCount == request.resource.data.likeUserIds.size() &&
        (
          (
            !(request.auth.uid in resource.data.likeUserIds) &&
            request.auth.uid in request.resource.data.likeUserIds &&
            request.resource.data.likeUserIds.size() ==
              resource.data.likeUserIds.size() + 1
          ) ||
          (
            request.auth.uid in resource.data.likeUserIds &&
            !(request.auth.uid in request.resource.data.likeUserIds) &&
            request.resource.data.likeUserIds.size() ==
              resource.data.likeUserIds.size() - 1
          )
        );
    }

    function isCommentCountIncrement() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'commentCount',
        ]) &&
        unchangedCommunityPostFields() &&
        request.resource.data.likeUserIds == resource.data.likeUserIds &&
        request.resource.data.likeCount == resource.data.likeCount &&
        request.resource.data.commentCount is int &&
        request.resource.data.commentCount == resource.data.commentCount + 1;
    }

    function canUpdateCommunityPost() {
      return signedIn() && (
        isLikeToggleUpdate() ||
        isCommentCountIncrement()
      );
    }

    function canDeleteCommunityPost() {
      return signedIn() && isCommunityAuthor(resource.data);
    }

    match /users/{userId} {
      allow read: if signedIn() || isOwnUser(userId);
      allow create, update, delete: if isOwnUser(userId) || isAdmin();
    }

    match /ads/{adId} {
      allow read: if true;
      allow create: if isAdmin() || canCreateAd();
      allow update: if isAdmin() || canWriteExistingAd() || isAdClickIncrement();
      allow delete: if isAdmin() || canWriteExistingAd();
    }

    match /stores/{storeId} {
      allow read: if true;
      allow create: if isAdmin() ||
        (
          signedIn() &&
          request.resource.data.ownerId == request.auth.uid
        );
      allow update: if isAdmin() || canPostAsStore(storeId);
      allow delete: if isAdmin() || canManageStore(storeId);
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAdmin() ||
        (
          signedIn() &&
          request.resource.data.reviewerId == request.auth.uid
        );
      allow update: if isAdmin() ||
        (
          signedIn() &&
          (
            resource.data.revieweeId == request.auth.uid ||
            resource.data.sellerId == request.auth.uid ||
            canPostAsStore(resource.data.storeId)
          )
        );
      allow delete: if isAdmin() ||
        (
          signedIn() &&
          (
            resource.data.reviewerId == request.auth.uid ||
            resource.data.revieweeId == request.auth.uid ||
            resource.data.sellerId == request.auth.uid ||
            canPostAsStore(resource.data.storeId)
          )
        );
    }

    match /review_requests/{requestId} {
      allow read: if isAdmin() ||
        (
          signedIn() &&
          (
            resource.data.buyerId == request.auth.uid ||
            resource.data.sellerId == request.auth.uid ||
            canPostAsStore(resource.data.storeId)
          )
        );
      allow create: if isAdmin() ||
        (
          signedIn() &&
          (
            request.resource.data.sellerId == request.auth.uid ||
            canPostAsStore(request.resource.data.storeId)
          )
        );
      allow update: if isAdmin() ||
        (
          signedIn() &&
          (
            resource.data.buyerId == request.auth.uid ||
            resource.data.sellerId == request.auth.uid ||
            canPostAsStore(resource.data.storeId)
          )
        );
      allow delete: if isAdmin();
    }

    match /chats/{chatId} {
      allow read, update, delete: if isAdmin() || isChatParticipant();
      allow create: if isAdmin() || isNewChatParticipant();

      match /messages/{messageId} {
        allow read, update, delete: if isAdmin() ||
          isChatParticipantById(chatId);
        allow create: if isAdmin() ||
          (
            request.resource.data.senderId == request.auth.uid &&
            isChatParticipantById(chatId)
          );
      }
    }

    match /support_chats/{chatId} {
      allow read: if isAdmin() || isOwnSupportChatId(chatId) || isSupportChatOwner();
      allow create: if isAdmin() || isNewSupportChatOwner();
      allow update: if isAdmin() || isSupportChatOwnerUpdate();
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isAdmin() || isSupportMessageOwner(chatId);
        allow create: if isAdmin() ||
          (
            isOpenSupportChatForMessage(chatId) &&
            (
              isSupportUserMessage(chatId) ||
              isSupportAutoMessage(chatId)
            )
          );
        allow update, delete: if isAdmin();
      }
    }

    match /maintenance_cleanup_queue/{docId} {
      allow create: if signedIn() || isAdmin();
      allow read, update, delete: if isAdmin();
    }

    match /app_config/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /community_posts/{postId} {
      allow read: if true;
      allow create: if canCreateCommunityPost(postId);
      allow update: if canUpdateCommunityPost();
      allow delete: if canDeleteCommunityPost();

      match /comments/{commentId} {
        allow read: if true;
        allow create: if signedIn()
          && request.resource.data.id == commentId
          && request.resource.data.postId == postId
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.message is string
          && request.resource.data.message.size() > 0;
        allow update, delete: if false;
      }
    }
  }
}
